# AI-Writer 配置示例
# 复制此文件为 .env 并填入你的配置

# ====================
# AI 模型配置
# ====================
MODEL_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen:7b-chat-q5_K_M

# DeepSeek API (可选)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Kimi API (可选)
KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-8k-vision-preview

# OpenAI API (可选，用于封面图生成)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# ====================
# 输出目录
# ====================
OUTPUT_DIR=~/GitHub/ai-writer-output

# ====================
# WordPress 配置
# ====================
WP_SITE_URL=https://yourblog.com
WP_USERNAME=your-username
WP_PASSWORD=your-app-password

# ====================
# 博客园配置
# ====================
CNBLOGS_BLOGNAME=your-blog-name
CNBLOGS_USERNAME=your-username
CNBLOGS_PASSWORD=your-password

# ====================
# 掘金配置
# ====================
JUEJIN_COOKIE=your-cookie-string
JUEJIN_CSRF_TOKEN=your-csrf-token

# ====================
# 知乎配置
# ====================
ZHIHU_COOKIE=your-cookie-string
ZHIHU_Z_C0=your-z-c0-token

# ====================
# CSDN 配置
# ====================
CSDN_COOKIE=your-cookie-string
CSDN_USERNAME=your-username

# ====================
# 小红书配置
# ====================
XIAOHONGSHU_COOKIE=your-cookie-string
XIAOHONGSHU_ACCESS_TOKEN=your-access-token

# ====================
# 微信公众号配置 (企业认证)
# ====================
WECHAT_APP_ID=your-app-id
WECHAT_APP_SECRET=your-app-secret
WECHAT_AUTHOR=AI写作助手

# ====================
# Web 服务配置
# ====================
WEB_PORT=3000
